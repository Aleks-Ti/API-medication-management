# event_microservice использует корневой .env
# docker-compose.yml и docker-compose.infra.yml автоматически переопределяют:
#   DEV=prod
#   PG_HOST=db
#   RMQ_HOST=mq
#
# Для локального запуска event_microservice отдельно (вне Docker),
# скопируй корневой .env и укажи:
#   DEV=local
#   PG_HOST=localhost
