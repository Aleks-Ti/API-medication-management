# ==========================================
# TELEGRAM BOT
# ==========================================
TOKEN=your_token_here

# ==========================================
# РЕЖИМ ЗАПУСКА
# local → бот локально, redis/mq в Docker (подключается через host.docker.internal)
# prod  → бот в Docker, redis/mq тоже в Docker (подключается по имени сервиса)
# ==========================================
DEV=local

# ==========================================
# RABBITMQ
# ==========================================
RMQ_NETWOTK_PORT=5672
RMQ_USER=rabbit
RMQ_PASSWORD=rabbit
# Используется только при DEV=prod
RMQ_HOST=mq

# ==========================================
# REDIS (хранилище состояний aiogram)
# ==========================================
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE_FOR_AIOGRAM=0

# ==========================================
# API URL
# BASE_URL_API_LOCAL     → DEV=local (бот локально, api тоже локально)
# BASE_URL_API_CONTAINER → DEV=local_container (бот в Docker, api в Docker)
# BASE_URL_API_PROD      → DEV=prod
# ==========================================
BASE_URL_API_LOCAL=http://localhost:8001/api
BASE_URL_API_CONTAINER=http://api:8001/api
BASE_URL_API_PROD=https://your-prod-domain.com/api
